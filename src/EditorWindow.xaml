<Window x:Class="WinSnipper.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSnipper"
        Background="#FF1E1F24"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        MinWidth="1180" MinHeight="600"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" ResizeBorderThickness="6"
                      GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="BarBg" Color="#FF24252B"/>
        <SolidColorBrush x:Key="GroupBg" Color="#FF2E2F36"/>
        <SolidColorBrush x:Key="BtnHover" Color="#FF3C3E48"/>
        <SolidColorBrush x:Key="AccentBg" Color="#FF3478F6"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF4A89F8"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFE8EAEE"/>
        <SolidColorBrush x:Key="TextDim" Color="#FF9AA0A8"/>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mac-like segmented control toggle -->
        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Padding" Value="13,5"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="B" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF36383F"/>
                                <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF4B4E59"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- window caption buttons -->
        <Style x:Key="CaptionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#26FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptionCloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#E6D64545"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- minimal slider -->
        <Style x:Key="SliderRepeat" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MinimalSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="18">
                            <Border Height="4" CornerRadius="2" Background="#FF3C3E48" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeat}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeat}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Width="14" Height="14"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- custom title bar (drag area via WindowChrome caption) -->
        <Grid DockPanel.Dock="Top" Background="{StaticResource BarBg}" Height="42">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0">
                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBg}" VerticalAlignment="Center"/>
                <TextBlock Text="WinSnipper" Foreground="{StaticResource TextDim}" FontSize="12"
                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="TitleText" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource TextDim}" FontSize="12.5"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Style="{StaticResource CaptionBtn}" Content="–" Click="Minimize_Click" ToolTip="Minimize"/>
                <Button Style="{StaticResource CaptionCloseBtn}" Content="✕" Click="CloseWindow_Click" ToolTip="Close (saves changes)"/>
            </StackPanel>
        </Grid>

        <!-- toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BarBg}"
                BorderBrush="#FF141518" BorderThickness="0,0,0,1" Padding="12,4,12,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource GroupBg}" CornerRadius="8" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="BtnRect" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Rect" Content="▭" FontSize="15" IsChecked="True" ToolTip="Rectangle"/>
                            <ToggleButton x:Name="BtnPen" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Pen" Content="✏" FontSize="15" ToolTip="Freehand draw"/>
                            <ToggleButton x:Name="BtnEllipse" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Ellipse" Content="◯" FontSize="15" ToolTip="Ellipse"/>
                            <ToggleButton x:Name="BtnArrow" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Arrow" Content="↗" FontSize="15" ToolTip="Arrow"/>
                            <ToggleButton x:Name="BtnText" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Text" Content="T" FontSize="15" FontWeight="Bold"
                                          ToolTip="Text — click to type, Enter to commit"/>
                            <ToggleButton x:Name="BtnBadge" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Badge" Content="①" FontSize="15" ToolTip="Step badge — click to drop 1, 2, 3…"/>
                            <ToggleButton x:Name="BtnPixelate" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Pixelate" Content="▦" FontSize="15"
                                          ToolTip="Redact — pixelate a region (hide keys / secrets)"/>
                            <ToggleButton x:Name="BtnCrop" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                                          Tag="Crop" Content="⬚" FontSize="15" ToolTip="Crop — drag a region, Enter to apply"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="ColorsPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0"/>
                    <Slider x:Name="ThicknessSlider" Style="{StaticResource MinimalSlider}" Width="96"
                            Minimum="1" Maximum="16" Value="3"
                            VerticalAlignment="Center" Margin="16,0,0,0"
                            IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="Stroke thickness"/>
                    <TextBlock x:Name="ThicknessLabel" Text="3" Foreground="{StaticResource TextDim}" Width="22"
                               TextAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnUndo" Style="{StaticResource ToolBtn}" Click="Undo_Click"
                            Content="↶" FontSize="16" Padding="9,3" ToolTip="Undo (Ctrl+Z)"/>
                    <Button x:Name="BtnRedo" Style="{StaticResource ToolBtn}" Click="Redo_Click"
                            Content="↷" FontSize="16" Padding="9,3" ToolTip="Redo (Ctrl+Y)"/>
                    <Rectangle Width="1" Fill="#FF3A3D45" Margin="10,4"/>
                    <Button x:Name="BtnOcr" Style="{StaticResource ToolBtn}" Click="Ocr_Click" Content="Copy Text"
                            ToolTip="OCR — copy all readable text in the image to the clipboard"/>
                    <Button Style="{StaticResource ToolBtn}" Click="Copy_Click" Content="Copy" ToolTip="Copy to clipboard (Ctrl+C)"/>
                    <Button Style="{StaticResource ToolBtn}" Click="Save_Click" Content="Save" ToolTip="Save (Ctrl+S)"/>
                    <Button Style="{StaticResource ToolBtn}" Click="SaveAs_Click" Content="Save As…"/>
                    <Button Style="{StaticResource AccentBtn}" Click="CopyClose_Click" Content="Copy &amp; Close"
                            Margin="10,0,0,0" ToolTip="Copy to clipboard, save, and close (Ctrl+Enter)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BarBg}"
                BorderBrush="#FF141518" BorderThickness="0,1,0,0" Padding="14,5">
            <DockPanel>
                <TextBlock x:Name="StatusZoom" DockPanel.Dock="Right" Foreground="{StaticResource TextDim}"
                           FontSize="12" ToolTip="Ctrl+Mouse wheel to zoom"/>
                <TextBlock x:Name="StatusSize" Foreground="{StaticResource TextDim}" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- canvas -->
        <ScrollViewer x:Name="Scroller" Background="#FF17181C"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Focusable="False"
                      PreviewMouseWheel="Scroller_PreviewMouseWheel">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="ZoomTf" ScaleX="1" ScaleY="1"/>
                </Border.LayoutTransform>
                <Grid x:Name="Surface" ClipToBounds="True">
                    <Image x:Name="BaseImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="Ink" Background="Transparent" Cursor="Cross"
                            MouseLeftButtonDown="Ink_Down" MouseMove="Ink_Move" MouseLeftButtonUp="Ink_Up"/>
                    <Canvas x:Name="CropLayer" Background="{x:Null}" Visibility="Collapsed">
                        <Path x:Name="CropDim" Fill="#77000000" IsHitTestVisible="False"/>
                        <Rectangle x:Name="CropSel" Stroke="White" StrokeThickness="1.5"
                                   StrokeDashArray="5 3" IsHitTestVisible="False" Visibility="Collapsed"/>
                        <Border x:Name="CropActions" Background="#F0222329" CornerRadius="8" Padding="4"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource AccentBtn}" Click="CropApply_Click"
                                        Content="✔ Crop" ToolTip="Apply crop (Enter)"/>
                                <Button Style="{StaticResource ToolBtn}" Click="CropCancel_Click"
                                        Content="✕" ToolTip="Cancel crop (Esc)"/>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
