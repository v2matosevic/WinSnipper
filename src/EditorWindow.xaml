<Window x:Class="WinSnipper.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSnipper"
        Background="#FF17181C"
        WindowStartupLocation="CenterScreen"
        MinWidth="640" MinHeight="440">
    <Window.Resources>
        <SolidColorBrush x:Key="BarBg" Color="#FF202227"/>
        <SolidColorBrush x:Key="BtnHover" Color="#FF33363E"/>
        <SolidColorBrush x:Key="AccentBg" Color="#FF2C5E96"/>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#FFDDE1E6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#FFDDE1E6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="B" Background="Transparent" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource AccentBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Sep" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Fill" Value="#FF3A3D45"/>
            <Setter Property="Margin" Value="8,3"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource BarBg}" Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton x:Name="BtnPen" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                              Tag="Pen" Content="✏ Draw" IsChecked="True" ToolTip="Freehand draw"/>
                <ToggleButton x:Name="BtnRect" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                              Tag="Rect" Content="▭ Rect" ToolTip="Rectangle"/>
                <ToggleButton x:Name="BtnEllipse" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                              Tag="Ellipse" Content="◯ Ellipse" ToolTip="Ellipse"/>
                <ToggleButton x:Name="BtnArrow" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                              Tag="Arrow" Content="↗ Arrow" ToolTip="Arrow"/>
                <ToggleButton x:Name="BtnCrop" Style="{StaticResource ToolToggle}" Click="Tool_Click"
                              Tag="Crop" Content="⬚ Crop" ToolTip="Crop — drag a region, Enter to apply"/>

                <Rectangle Style="{StaticResource Sep}"/>
                <StackPanel x:Name="ColorsPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                <Rectangle Style="{StaticResource Sep}"/>

                <TextBlock Text="Size" Foreground="#FF9AA0A6" VerticalAlignment="Center" Margin="2,0,7,0" FontSize="12"/>
                <Slider x:Name="ThicknessSlider" Width="90" Minimum="1" Maximum="16" Value="3"
                        VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                <TextBlock x:Name="ThicknessLabel" Text="3" Foreground="#FF9AA0A6" Width="22"
                           TextAlignment="Center" VerticalAlignment="Center" FontSize="12"/>

                <Rectangle Style="{StaticResource Sep}"/>
                <Button x:Name="BtnUndo" Style="{StaticResource ToolBtn}" Click="Undo_Click"
                        Content="↶" FontSize="16" Padding="8,3" ToolTip="Undo (Ctrl+Z)"/>
                <Button x:Name="BtnRedo" Style="{StaticResource ToolBtn}" Click="Redo_Click"
                        Content="↷" FontSize="16" Padding="8,3" ToolTip="Redo (Ctrl+Y)"/>

                <Rectangle Style="{StaticResource Sep}"/>
                <Button Style="{StaticResource ToolBtn}" Click="Copy_Click" Content="Copy" ToolTip="Copy to clipboard (Ctrl+C)"/>
                <Button Style="{StaticResource ToolBtn}" Click="Save_Click" Content="Save" ToolTip="Save (Ctrl+S)"/>
                <Button Style="{StaticResource ToolBtn}" Click="SaveAs_Click" Content="Save As…"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource BarBg}" Padding="12,4">
            <DockPanel>
                <TextBlock x:Name="StatusZoom" DockPanel.Dock="Right" Foreground="#FF9AA0A6" FontSize="12"
                           ToolTip="Ctrl+Mouse wheel to zoom"/>
                <TextBlock x:Name="StatusSize" Foreground="#FF9AA0A6" FontSize="12"/>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="Scroller" Background="#FF101114"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Focusable="False"
                      PreviewMouseWheel="Scroller_PreviewMouseWheel">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="ZoomTf" ScaleX="1" ScaleY="1"/>
                </Border.LayoutTransform>
                <Grid x:Name="Surface" ClipToBounds="True">
                    <Image x:Name="BaseImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="Ink" Background="Transparent" Cursor="Cross"
                            MouseLeftButtonDown="Ink_Down" MouseMove="Ink_Move" MouseLeftButtonUp="Ink_Up"/>
                    <Canvas x:Name="CropLayer" Background="{x:Null}" Visibility="Collapsed">
                        <Path x:Name="CropDim" Fill="#77000000" IsHitTestVisible="False"/>
                        <Rectangle x:Name="CropSel" Stroke="White" StrokeThickness="1.5"
                                   StrokeDashArray="5 3" IsHitTestVisible="False" Visibility="Collapsed"/>
                        <Border x:Name="CropActions" Background="#E61B1E24" CornerRadius="6" Padding="3"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolBtn}" Click="CropApply_Click"
                                        Background="{StaticResource AccentBg}" Content="✔ Crop" ToolTip="Apply crop (Enter)"/>
                                <Button Style="{StaticResource ToolBtn}" Click="CropCancel_Click"
                                        Content="✕" ToolTip="Cancel crop (Esc)"/>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
