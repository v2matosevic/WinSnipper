<Window x:Class="WinSnipper.FloatingThumb"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="-10000" Top="-10000"
        MouseEnter="Win_MouseEnter"
        MouseLeave="Win_MouseLeave">
    <Window.Resources>
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE6E8EC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="#CC202229" CornerRadius="11"
                                BorderBrush="#33FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#E6D64545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="Root" Margin="12" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="EnterTf"/>
        </Grid.RenderTransform>
        <Border x:Name="Card"
                CornerRadius="10"
                Background="#FF1C1D22"
                BorderBrush="#4DFFFFFF"
                BorderThickness="1"
                MouseLeftButtonDown="Card_MouseLeftButtonDown"
                MouseMove="Card_MouseMove"
                MouseLeftButtonUp="Card_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.45" Color="#FF000000"/>
            </Border.Effect>
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Pin (keep on screen)" Click="Pin_Click"/>
                    <MenuItem Header="Edit" Click="Edit_Click"/>
                    <MenuItem Header="Copy image" Click="Copy_Click"/>
                    <MenuItem Header="Copy file path" Click="CopyPath_Click"/>
                    <MenuItem Header="Save as…" Click="SaveAs_Click"/>
                    <Separator/>
                    <MenuItem Header="Open in default viewer" Click="OpenDefault_Click"/>
                    <MenuItem Header="Show in folder" Click="ShowInFolder_Click"/>
                    <Separator/>
                    <MenuItem Header="Dismiss" Click="CloseItem_Click"/>
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Image x:Name="Thumb"
                       Margin="3"
                       MinWidth="50" MinHeight="34"
                       MaxWidth="190" MaxHeight="120"
                       Stretch="Uniform"
                       SizeChanged="Thumb_SizeChanged"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Button x:Name="CloseBtn" Content="✕" ToolTip="Dismiss"
                        Style="{StaticResource CloseBtnStyle}"
                        VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="6" Visibility="Collapsed"
                        Click="CloseItem_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
