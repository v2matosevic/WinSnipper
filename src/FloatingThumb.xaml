<Window x:Class="WinSnipper.FloatingThumb"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="-10000" Top="-10000"
        MouseEnter="Win_MouseEnter"
        MouseLeave="Win_MouseLeave">
    <Window.Resources>
        <Style x:Key="ThumbBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE6E8EC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="Transparent" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF3A3E48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Border x:Name="Card"
                CornerRadius="9"
                Background="#FF1C1D22"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                MouseLeftButtonDown="Card_MouseLeftButtonDown"
                MouseMove="Card_MouseMove"
                MouseLeftButtonUp="Card_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.55"/>
            </Border.Effect>
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Click="Edit_Click"/>
                    <MenuItem Header="Copy image" Click="Copy_Click"/>
                    <MenuItem Header="Copy file path" Click="CopyPath_Click"/>
                    <MenuItem Header="Save as…" Click="SaveAs_Click"/>
                    <Separator/>
                    <MenuItem Header="Open in default viewer" Click="OpenDefault_Click"/>
                    <MenuItem Header="Show in folder" Click="ShowInFolder_Click"/>
                    <Separator/>
                    <MenuItem Header="Dismiss" Click="CloseItem_Click"/>
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Image x:Name="Thumb"
                       Margin="3"
                       MinWidth="50" MinHeight="34"
                       MaxWidth="190" MaxHeight="120"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border x:Name="ToolsBar"
                        VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="7" CornerRadius="6"
                        Background="#E61B1E24"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Button Content="⠿" ToolTip="Move the thumbnail on screen"
                                Style="{StaticResource ThumbBtn}" Cursor="SizeAll"
                                PreviewMouseLeftButtonDown="Grip_Down"/>
                        <Button Content="✏" ToolTip="Edit (double-click also opens the editor)"
                                Style="{StaticResource ThumbBtn}" Click="Edit_Click"/>
                        <Button Content="⧉" ToolTip="Copy image to clipboard"
                                Style="{StaticResource ThumbBtn}" Click="Copy_Click"/>
                        <Button Content="✕" ToolTip="Dismiss"
                                Style="{StaticResource ThumbBtn}" Click="CloseItem_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
