<Window x:Class="WinSnipper.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSnipper Settings"
        Background="#FF1E1F24"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="480"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        ShowInTaskbar="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" ResizeBorderThickness="0"
                      GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="BarBg" Color="#FF24252B"/>
        <SolidColorBrush x:Key="GroupBg" Color="#FF2B2C33"/>
        <SolidColorBrush x:Key="BtnHover" Color="#FF3C3E48"/>
        <SolidColorBrush x:Key="AccentBg" Color="#FF3478F6"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF4A89F8"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFE8EAEE"/>
        <SolidColorBrush x:Key="TextDim" Color="#FF9AA0A8"/>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="Background" Value="{StaticResource GroupBg}"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource BtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#E6D64545"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- title bar -->
        <Grid DockPanel.Dock="Top" Background="{StaticResource BarBg}" Height="42">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0">
                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBg}" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" Foreground="{StaticResource TextFg}" FontSize="13"
                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Style="{StaticResource CaptionCloseBtn}" Content="✕" Click="Cancel_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
        </Grid>

        <StackPanel Margin="22,18,22,20">
            <!-- hotkey -->
            <TextBlock Style="{StaticResource Label}" Text="Capture hotkey"/>
            <Button x:Name="HotkeyBox" Style="{StaticResource FlatBtn}" Click="HotkeyBox_Click"
                    HorizontalAlignment="Left" MinWidth="200" Margin="0,7,0,0"
                    HorizontalContentAlignment="Center"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="Click, then press the combination you want (e.g. Win + Shift + S). Esc cancels."/>

            <!-- dismiss -->
            <TextBlock Style="{StaticResource Label}" Text="Thumbnail auto-dismiss" Margin="0,18,0,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                <Slider x:Name="DismissSlider" Width="220" Minimum="1" Maximum="15"
                        IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                <TextBlock x:Name="DismissLabel" Style="{StaticResource Label}" Margin="12,0,0,0" Width="60"/>
            </StackPanel>

            <!-- save folder -->
            <TextBlock Style="{StaticResource Label}" Text="Save snips to" Margin="0,18,0,0"/>
            <DockPanel Margin="0,7,0,0">
                <Button Style="{StaticResource FlatBtn}" Content="Browse…" Click="Browse_Click" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Border Background="{StaticResource GroupBg}" CornerRadius="7" Padding="10,7">
                    <TextBlock x:Name="SaveDirText" Foreground="{StaticResource TextDim}" FontSize="12.5"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </DockPanel>

            <!-- OCR (collapsed entirely in the lite build) -->
            <StackPanel x:Name="OcrSection">
                <TextBlock Style="{StaticResource Label}" Text="Text recognition (OCR)" Margin="0,18,0,0"/>
                <DockPanel Margin="0,7,0,0">
                    <Button x:Name="OcrInstallBtn" Style="{StaticResource FlatBtn}" Content="Install…"
                            Click="OcrInstall_Click" DockPanel.Dock="Right" Margin="8,0,0,0"
                            Visibility="Collapsed"/>
                    <Border Background="{StaticResource GroupBg}" CornerRadius="7" Padding="10,7">
                        <TextBlock x:Name="OcrStatusText" Foreground="{StaticResource TextDim}" FontSize="12.5"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DockPanel>
                <TextBlock x:Name="OcrHint" Style="{StaticResource Hint}" Visibility="Collapsed"
                           Text="Installing adds the Windows OCR pack for your language (admin prompt, ~1 min). Restart WinSnipper afterwards."/>
            </StackPanel>

            <!-- toggles -->
            <CheckBox x:Name="ClipboardCheck" Content="Copy every snip to the clipboard automatically" Margin="0,18,0,0"/>
            <CheckBox x:Name="StartupCheck" Content="Start WinSnipper with Windows" Margin="0,10,0,0"/>

            <!-- footer -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Style="{StaticResource FlatBtn}" Content="Cancel" Click="Cancel_Click" MinWidth="84"/>
                <Button Style="{StaticResource AccentBtn}" Content="Save" Click="Save_Click" MinWidth="84" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
