<Window x:Class="WinSnipper.SnipOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="0" Top="0" Width="200" Height="200"
        Background="Black"
        Cursor="Cross">
    <Grid>
        <Image x:Name="ScreenImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        <Path x:Name="DimPath" Fill="#59000000" IsHitTestVisible="False"/>
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="SelRect" Stroke="#FF53A7FF" StrokeThickness="1.5" Visibility="Collapsed"/>
            <Border x:Name="SizeBadge" Background="#CC1B1E23" CornerRadius="4" Padding="7,3" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Consolas"/>
            </Border>
        </Canvas>
        <Border x:Name="HintBadge"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,28,0,0"
                Background="#CC1B1E23" CornerRadius="6" Padding="16,9" IsHitTestVisible="False">
            <TextBlock Foreground="#EEEEEE" FontSize="13"
                       Text="Drag to capture a region   ·   Esc to cancel"/>
        </Border>
    </Grid>
</Window>
